# ============================================================
#  DRONE DASHBOARD — CONFIGURATION
#  Edit this file to connect to your local services.
#  Restart `npm run dev` after changing any value.
# ============================================================

# ── Ollama (LLM) ──────────────────────────────────────────
# Default: http://localhost:11434
# Change only if Ollama is running on a different machine/port
VITE_OLLAMA_URL=http://localhost:11434

# Which model to use (must be pulled via `ollama pull <name>`)
VITE_OLLAMA_MODEL=phi3

# ── ROS Bridge ────────────────────────────────────────────
# IP of the machine running rosbridge_server
# Example: VITE_ROS_SERVER_IP=192.168.1.42
VITE_ROS_SERVER_IP=192.168.7.5

# rosbridge WebSocket port (default: 9090)
VITE_ROS_WS_PORT=9090

# Camera topic to stream
VITE_CAMERA_TOPIC=/gimbal/camera/image
VITE_VIDEO_PORT=8080

# ── ROS Topics ────────────────────────────────────────────
VITE_TOPIC_ODOM=/fmu/out/vehicle_local_position_v1
VITE_TOPIC_CMD_VEL=/user_command

# ── Safety Limits ─────────────────────────────────────────
VITE_MAX_LINEAR_VEL=1.5
VITE_MAX_ANGULAR_VEL=1.0
